. 
. use "$datadir\cars_ps.dta", clear

. 
. egen mkt = group(country year)

. gen M = pop / 3

. bysort mkt: egen total_q = total(qu)

. gen sj = qu / M

. gen s0 = (M - total_q) / M

. assert s0 > 0

. gen lnsj_s0 = ln(sj) - ln(s0)

. bysort mkt class: egen group_q = total(qu)

. gen sjg = qu / group_q

. gen ln_sjg_small  = ln(sjg) * (class == 1)

. gen ln_sjg_medium = ln(sjg) * (class == 2)

. gen ln_sjg_luxury = ln(sjg) * (class == 3)

. 
. local chars "horsepower fuel width height"

. foreach var of local chars {
  2.     bysort mkt: egen sum_`var'_mkt = total(`var')
  3.     bysort mkt firm: egen sum_`var'_firm = total(`var')
  4.     bysort mkt class: egen sum_`var'_grp = total(`var')
  5.     bysort mkt firm class: egen sum_`var'_fgrp = total(`var')
  6.     gen iv_`var'_rival = sum_`var'_mkt - sum_`var'_firm
  7.     gen iv_`var'_own   = sum_`var'_firm - `var'
  8.     gen iv_`var'_grp   = sum_`var'_grp - `var'
  9.     gen iv_`var'_fgrp  = sum_`var'_fgrp - `var'
 10. }

. 
. bysort mkt: gen n_mkt = _N

. bysort mkt firm: gen n_firm_mkt = _N

. bysort mkt class: gen n_grp = _N

. bysort mkt firm class: gen n_fgrp = _N

. gen iv_n_rival = n_mkt - n_firm_mkt

. gen iv_n_own   = n_firm_mkt - 1

. gen iv_n_grp   = n_grp - 1

. gen iv_n_fgrp  = n_fgrp - 1

. 
. global ivlist "iv_horsepower_rival iv_fuel_rival iv_width_rival iv_height_riv
> al iv_horsepower_own iv_fuel_own iv_width_own iv_height_own iv_horsepower_grp
>  iv_fuel_grp iv_width_grp iv_height_grp iv_horsepower_fgrp iv_fuel_fgrp iv_wi
> dth_fgrp iv_height_fgrp iv_n_rival iv_n_own iv_n_grp iv_n_fgrp"

. 
